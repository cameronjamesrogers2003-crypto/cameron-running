generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Activity {
  id              String   @id
  name            String?
  date            DateTime
  distanceKm      Float
  durationSecs    Int
  avgPaceSecKm    Int
  avgHeartRate    Int?
  maxHeartRate    Int?
  calories        Int?
  activityType    String
  syncedAt        DateTime @default(now())
  elapsedTimeSecs Int?
  elevationGainM  Float?
  startLat        Float?
  startLon        Float?
  manual          Boolean  @default(false)
  splits          Json?
  temperatureC    Float?
  humidityPct     Float?
}

model Profile {
  id                Int       @id @default(1)
  name              String    @default("Cameron")
  dateOfBirth       DateTime
  heightCm          Int       @default(174)
  stravaConnected   Boolean   @default(false)
  stravaToken       String?
  stravaRefresh     String?
  stravaTokenExpiry DateTime?
}
