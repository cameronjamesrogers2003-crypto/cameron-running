generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Activity {
  id                 String   @id
  name               String?
  date               DateTime
  distanceKm         Float
  durationSecs       Int
  avgPaceSecKm       Int
  avgHeartRate       Int?
  maxHeartRate       Int?
  calories           Int?
  activityType       String
  syncedAt           DateTime @default(now())
  elapsedTimeSecs    Int?
  elevationGainM     Float?
  startLat           Float?
  startLon           Float?
  manual             Boolean  @default(false)
  splits             Json?
  temperatureC       Float?
  humidityPct        Float?
  // 0–10 run quality score (calculateRunRating + sync/backfill only)
  rating             Float?
  // JSON: RunRatingResult (components + reasons); null before backfill
  ratingBreakdown    String?
  // Pace-zone type from classifyRunByPaceZones; kept in sync with rating
  classifiedRunType  String?
}

model Profile {
  id                Int       @id @default(1)
  name              String    @default("Cameron")
  dateOfBirth       DateTime
  heightCm          Int       @default(174)
  stravaConnected   Boolean   @default(false)
  stravaToken       String?
  stravaRefresh     String?
  stravaTokenExpiry DateTime?
  lastRefreshedAt   DateTime?
}

model UserSettings {
  id                    Int       @id @default(1)
  planStartDate         DateTime?
  currentWeekOverride   Int?
  phaseOverride         String?
  experienceLevel       ExperienceLevel?
  goalRace              String?
  planLengthWeeks       Int?
  targetFinishTime      Int?
  trainingDays          String?
  sessionAssignment     String?
  maxHR                 Int       @default(198)
  startingTempoPaceSec  Int       @default(390)
  currentVdot           Int       @default(33)
  targetHMTimeSec       Int       @default(6900)
  raceName              String?
  raceDate              DateTime?
  distTargetEasyM       Int       @default(7000)
  distTargetTempoM      Int       @default(10000)
  distTargetIntervalM   Int       @default(8000)
  distTargetLongM       Int       @default(18000)
  easyPaceMinSec        Int       @default(390)
  easyPaceMaxSec        Int       @default(450)
  tempoPaceMinSec       Int       @default(330)
  tempoPaceMaxSec       Int       @default(390)
  intervalPaceMinSec    Int       @default(300)
  intervalPaceMaxSec    Int       @default(330)
  longPaceMinSec        Int       @default(390)
  longPaceMaxSec        Int       @default(450)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model PlayerRating {
  id               String   @id @default(cuid())
  updatedAt        DateTime @updatedAt
  overall          Float
  speed            Float
  endurance        Float
  consistency      Float
  hrEfficiency     Float
  toughness        Float
  prevOverall      Float
  prevSpeed        Float
  prevEndurance    Float
  prevConsistency  Float
  prevHrEfficiency Float
  prevToughness    Float
}

model PlanInterruption {
  id               String    @id @default(cuid())
  reason           String
  type             String
  startDate        DateTime
  endDate          DateTime?
  weeklyKmEstimate Float?
  notes            String?
  weeksAffected    Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model GeneratedPlan {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  planJson    String
  configJson  String
  lockedWeeks String?
}
